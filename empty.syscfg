const Board = scripting.addModule("/ti/driverlib/Board", {}, false);

GPIO2.$name                         = "RED_GPIO";
GPIO2.associatedPins[0].$name       = "PIN_0";
GPIO2.associatedPins[0].ioStructure = "SD";

GPIO3.$name                               = "MODE_GPIO";
GPIO3.port                                = "PORTA";
GPIO3.associatedPins[0].$name             = "PIN_1";
GPIO3.associatedPins[0].ioStructure       = "SDW";
GPIO3.associatedPins[0].interruptEn       = true;
GPIO3.associatedPins[0].pubChanID         = 1;
GPIO3.associatedPins[0].polarity          = "FALL";
GPIO3.associatedPins[0].interruptPriority = "1";
GPIO3.associatedPins[0].internalResistor  = "PULL_UP";
GPIO3.associatedPins[0].direction         = "INPUT";

GPIO4.$name                               = "CONF_GPIO";
GPIO4.associatedPins[0].$name             = "PIN_2";
GPIO4.associatedPins[0].direction         = "INPUT";
GPIO4.associatedPins[0].ioStructure       = "SD";
GPIO4.associatedPins[0].internalResistor  = "PULL_UP";
GPIO4.associatedPins[0].interruptEn       = true;
GPIO4.associatedPins[0].interruptPriority = "1";
GPIO4.associatedPins[0].polarity          = "FALL";
